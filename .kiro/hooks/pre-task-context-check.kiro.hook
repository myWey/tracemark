{
  "name": "Pre-task context check",
  "version": "1.0.0",
  "description": "Before running a Kiro spec task, verify required reading is loaded and maps are fresh.",
  "when": {
    "type": "preTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Verify the AGENTS.md required reading is loaded for this session. If any file under .agent/map/ has a stale Source-hash, run .agent/workflows/regenerate-map.md first. Otherwise proceed."
  }
}
