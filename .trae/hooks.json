{
  "description": "agentOS guardrails and automation hooks. Compatible with Trae/Claude Code Hook protocol: stdin JSON input, stdout JSON decisions, exit 0/2.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .trae/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|DeleteFile",
        "hooks": [
          {
            "type": "command",
            "command": "bash .trae/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .trae/hooks/post-edit-lint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .trae/hooks/stop-check.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .trae/hooks/prompt-guard.sh"
          }
        ]
      }
    ]
  }
}
